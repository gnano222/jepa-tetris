# Copy to .env.runpod and fill in values. Never commit .env.runpod.
RUNPOD_API_KEY=your_api_key_here
RUNPOD_VOLUME_ID=your_network_volume_id_here
RUNPOD_IMAGE=YOUR_DOCKERHUB_USER/jepa-tetris-runpod:latest
GITHUB_REPO=https://github.com/YOUR_USER/jepa-tetris.git

# Optional: training parameters (overrides defaults in pod_startup.sh)
JEPA_BUFFER=data/buffer.npz
JEPA_STEPS=50000
JEPA_HORIZON=4
JEPA_RUN=run01
JEPA_OUT=checkpoints/jepa.pt
